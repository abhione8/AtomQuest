generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum GoalSheetStatus {
  DRAFT
  SUBMITTED
  RETURNED
  APPROVED
  LOCKED
}

enum UomType {
  NUMERIC_MIN
  NUMERIC_MAX
  PERCENT_MIN
  PERCENT_MAX
  TIMELINE
  ZERO_BASED
}

enum Quarter {
  Q1
  Q2
  Q3
  Q4
  ANNUAL
}

enum CheckinStatus {
  NOT_STARTED
  ON_TRACK
  COMPLETED
}

enum ApprovalActionType {
  SUBMITTED
  EDITED_BY_MANAGER
  RETURNED
  APPROVED
  UNLOCKED
}

enum CycleStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum AuditEntityType {
  GOAL_SHEET
  GOAL
  CHECKIN
  SHARED_GOAL
  CYCLE
  USER
}

enum AuditActionType {
  CREATE
  UPDATE
  DELETE
  SUBMIT
  APPROVE
  RETURN
  UNLOCK
}

model User {
  id                        String    @id @default(cuid())
  email                     String    @unique
  password                  String
  name                      String
  role                      UserRole
  departmentId              String?
  department                Department?       @relation(fields: [departmentId], references: [id])
  employeeProfile           EmployeeProfile?
  managerRelations          ReportingManagerRelation[] @relation("employee")
  directReports             ReportingManagerRelation[] @relation("manager")
  goalSheets                GoalSheet[]
  approvalActions           ApprovalAction[]
  checkinComments           CheckinComment[]
  auditLogs                 AuditLog[]
  notifications             Notification[]
  
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@index([role])
  @@index([departmentId])
  @@index([email])
}

model Department {
  id                String    @id @default(cuid())
  name              String    @unique
  description       String?
  users             User[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model EmployeeProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId        String    @unique
  joinDate          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model ReportingManagerRelation {
  id                String    @id @default(cuid())
  employeeId        String
  employee          User      @relation("employee", fields: [employeeId], references: [id], onDelete: Cascade)
  managerId         String
  manager           User      @relation("manager", fields: [managerId], references: [id], onDelete: Cascade)
  cycleId           String?
  cycle             GoalCycle?  @relation(fields: [cycleId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([employeeId, managerId, cycleId])
  @@index([employeeId])
  @@index([managerId])
  @@index([cycleId])
}

model GoalCycle {
  id                String    @id @default(cuid())
  name              String
  status            CycleStatus @default(DRAFT)
  startDate         DateTime
  endDate           DateTime
  q1StartDate       DateTime?
  q1EndDate         DateTime?
  q2StartDate       DateTime?
  q2EndDate         DateTime?
  q3StartDate       DateTime?
  q3EndDate         DateTime?
  q4StartDate       DateTime?
  q4EndDate         DateTime?
  goalSheets        GoalSheet[]
  reportingRelations ReportingManagerRelation[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([startDate, endDate])
}

model GoalSheet {
  id                String    @id @default(cuid())
  employeeId        String
  employee          User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cycleId           String
  cycle             GoalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  status            GoalSheetStatus @default(DRAFT)
  goals             Goal[]
  approvalActions   ApprovalAction[]
  checkins          QuarterlyCheckin[]
  auditLogs         AuditLog[]
  totalWeightage    Float     @default(0)
  isLocked          Boolean   @default(false)
  
  submittedAt       DateTime?
  approvedAt        DateTime?
  lockedAt          DateTime?
  unlockedAt        DateTime?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([employeeId, cycleId])
  @@index([employeeId])
  @@index([cycleId])
  @@index([status])
}

model Goal {
  id                String    @id @default(cuid())
  goalSheetId       String
  goalSheet         GoalSheet @relation(fields: [goalSheetId], references: [id], onDelete: Cascade)
  thrustArea        String
  title             String
  description       String
  uomType           UomType
  target            Float
  weightage         Float     @default(0)
  baselineValue     Float?
  minTarget         Float?
  maxTarget         Float?
  
  sharedGoalId      String?
  sharedGoal        SharedGoalTemplate? @relation("primary", fields: [sharedGoalId], references: [id])
  
  recipientAssignments SharedGoalAssignment[]
  
  checkins          QuarterlyCheckin[]
  auditLogs         AuditLog[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([goalSheetId])
  @@index([sharedGoalId])
}

model SharedGoalTemplate {
  id                String    @id @default(cuid())
  title             String
  description       String
  thrustArea        String
  uomType           UomType
  target            Float
  baselineValue     Float?
  minTarget         Float?
  maxTarget         Float?
  
  primaryGoals      Goal[]    @relation("primary")
  assignments       SharedGoalAssignment[]
  auditLogs         AuditLog[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model SharedGoalAssignment {
  id                String    @id @default(cuid())
  sharedGoalId      String
  sharedGoal        SharedGoalTemplate @relation(fields: [sharedGoalId], references: [id], onDelete: Cascade)
  recipientGoalId   String
  recipientGoal     Goal      @relation(fields: [recipientGoalId], references: [id], onDelete: Cascade)
  
  recipientWeightage Float    @default(0)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([sharedGoalId, recipientGoalId])
  @@index([sharedGoalId])
  @@index([recipientGoalId])
}

model ApprovalAction {
  id                String    @id @default(cuid())
  goalSheetId       String
  goalSheet         GoalSheet @relation(fields: [goalSheetId], references: [id], onDelete: Cascade)
  
  actionType        ApprovalActionType
  actionBy          String
  actionByUser      User      @relation(fields: [actionBy], references: [id])
  
  comments          String?
  changedFields     String?
  
  createdAt         DateTime  @default(now())

  @@index([goalSheetId])
  @@index([actionBy])
  @@index([actionType])
}

model QuarterlyCheckin {
  id                String    @id @default(cuid())
  goalId            String
  goal              Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  goalSheetId       String
  goalSheet         GoalSheet @relation(fields: [goalSheetId], references: [id], onDelete: Cascade)
  
  quarter           Quarter
  status            CheckinStatus @default(NOT_STARTED)
  actualValue       Float?
  progressScore     Float?
  comments          String?
  
  comments_rel      CheckinComment[]
  auditLogs         AuditLog[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([goalId, quarter])
  @@index([goalId])
  @@index([goalSheetId])
  @@index([quarter])
}

model CheckinComment {
  id                String    @id @default(cuid())
  checkinId         String
  checkin           QuarterlyCheckin @relation(fields: [checkinId], references: [id], onDelete: Cascade)
  
  commentBy         String
  commentByUser     User      @relation(fields: [commentBy], references: [id])
  
  comment           String
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([checkinId])
  @@index([commentBy])
}

model AuditLog {
  id                String    @id @default(cuid())
  entityType        AuditEntityType
  entityId          String
  actionType        AuditActionType
  
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  goalSheetId       String?
  goalSheet         GoalSheet? @relation(fields: [goalSheetId], references: [id], onDelete: SetNull)
  
  goalId            String?
  goal              Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)
  
  checkinId         String?
  checkin           QuarterlyCheckin? @relation(fields: [checkinId], references: [id], onDelete: SetNull)
  
  sharedGoalId      String?
  sharedGoal        SharedGoalTemplate? @relation(fields: [sharedGoalId], references: [id], onDelete: SetNull)
  
  cycleId           String?
  changes           String?
  
  createdAt         DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([actionType])
  @@index([goalSheetId])
  @@index([goalId])
  @@index([checkinId])
}

model Notification {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title             String
  message           String
  type              String
  relatedEntityId   String?
  
  isRead            Boolean   @default(false)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([isRead])
}

model EscalationRule {
  id                String    @id @default(cuid())
  name              String
  description       String?
  daysAfterSubmission Int?
  escalateToRole    UserRole?
  
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
